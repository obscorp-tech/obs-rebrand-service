# Force LF line endings for all text files (prevents CRLF on Windows checkout)
* text=auto eol=lf

# Explicit text file types
*.py text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.sh text eol=lf
Dockerfile text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
.env* text eol=lf

# Binary files — no line ending conversion
templates/logos/**/*.png filter=lfs diff=lfs merge=lfs -text
templates/logos/**/*.jpg filter=lfs diff=lfs merge=lfs -text
templates/logos/**/*.jpeg filter=lfs diff=lfs merge=lfs -text
templates/logos/**/*.svg filter=lfs diff=lfs merge=lfs -text
templates/logos/**/*.gif filter=lfs diff=lfs merge=lfs -text
