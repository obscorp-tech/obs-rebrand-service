# Rebrand Service Environment Variables
# Copy to .env and adjust values. Never commit .env to Git.

REBRAND_PORT=8000
LOG_LEVEL=info

# Override repo URL if not using obscorp default
# REBRAND_REPO_URL=git@github.com:your-org/rebrand-service.git

# Override install directory
# REBRAND_INSTALL_DIR=/opt/rebrand-service
